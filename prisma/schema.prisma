generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DailyReport {
  id        Int       @id @default(autoincrement())
  date      DateTime  @unique @db.Date
  projects  Project[]
  createdAt DateTime  @default(now())

  @@map("daily_reports")
}

model Project {
  id           Int          @id @default(autoincrement())
  name         String
  owner        String
  fullName     String       @unique
  githubUrl    String
  description  String?
  language     String?
  stars        Int          @default(0)
  starsGrowth  Int          @default(0)
  rank         Int
  topics       String[]     @default([])
  analysisMd   String?
  report       DailyReport  @relation(fields: [reportDate], references: [date])
  reportDate   DateTime     @db.Date
  createdAt    DateTime     @default(now())

  @@map("projects")
}

model StarSnapshot {
  id          Int      @id @default(autoincrement())
  fullName    String
  stars       Int
  snapshotDate DateTime @db.Date

  @@unique([fullName, snapshotDate])
  @@map("star_snapshots")
}
