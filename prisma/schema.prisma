generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DailyReport {
  id        Int       @id @default(autoincrement())
  date      DateTime  @db.Date
  category  String    @default("stars")
  projects  Project[]
  createdAt DateTime  @default(now())

  @@unique([date, category])
  @@map("daily_reports")
}

model Project {
  id           Int          @id @default(autoincrement())
  name         String
  owner        String
  fullName     String
  githubUrl    String
  description  String?
  language     String?
  stars        Int          @default(0)
  forks        Int          @default(0)
  openIssues   Int          @default(0)
  starsGrowth  Int          @default(0)
  rank         Int
  topics       String[]     @default([])
  analysisMd   String?
  wechatMd     String?
  report       DailyReport  @relation(fields: [reportId], references: [id])
  reportId     Int
  createdAt    DateTime     @default(now())

  @@map("projects")
}

model StarSnapshot {
  id           Int      @id @default(autoincrement())
  fullName     String
  stars        Int
  snapshotDate DateTime @db.Date

  @@unique([fullName, snapshotDate])
  @@map("star_snapshots")
}
